# ============ SMART ATTENDANCE SYSTEM - ENVIRONMENT TEMPLATE ============
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file with real credentials!

# ============ Backend (FastAPI) Configuration ============
FASTAPI_ENV=development
FASTAPI_DEBUG=true
FASTAPI_RELOAD=true

# Backend Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ============ Firebase Configuration (Backend) ============
FIREBASE_CREDENTIALS_PATH=config/firebase-credentials.json
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_API_KEY=your-firebase-api-key

# ============ ML Model Configuration (Backend) ============
YOLOV8_MODEL_PATH=weights/yolov8n-face.pt
YOLOV8_CONFIDENCE_THRESHOLD=0.5
FACENET_MODEL_PATH=weights/facenet_model.pt
FACE_RECOGNITION_THRESHOLD=0.6

# ============ Frontend (React) Configuration ============
VITE_API_BASE_URL=http://localhost:8000
VITE_API_PREFIX=/api/v1

# ============ Logging Configuration ============
LOG_LEVEL=INFO
LOG_FILE=logs/attendance_system.log

# ============ Database Retention ============
ATTENDANCE_RETENTION_DAYS=365
