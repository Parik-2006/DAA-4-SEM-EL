## Example environment variables for Smart Attendance
# Copy this to .env and fill with production values (DO NOT COMMIT .env)

# JWT secret used to sign access tokens (use a strong random value in prod)
JWT_SECRET=change_me_to_a_strong_secret

# Firebase credentials path (local dev only) — production should use env var or secret manager
FIREBASE_CREDENTIALS_PATH=config/firebase-credentials.json

# App settings
SYSTEM_NAME=SmartAttendance
SYSTEM_ENV=development

# Rate limiting (optional overrides)
RATE_LIMIT_STUDENT=100
RATE_LIMIT_TEACHER=500

# Other optional envs
SENTRY_DSN=
DATABASE_URL=
# ==========================================
# Smart Attendance System - Environment Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
# ==========================================

# ========== Backend (FastAPI) ==========
# FastAPI server configuration
DEBUG=False
ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# Server host and port
HOST=0.0.0.0
PORT=8000
RELOAD=True

# Database
DATABASE_URL=sqlite:///./attendance.db
DATABASE_ECHO=False
REDIS_URL=

# Attendance timing / period detection
ATTENDANCE_WINDOW_MINUTES=10
LATE_THRESHOLD_MINUTES=5
NOTIFICATION_TRIGGER_MINUTES=5
PERIOD_DETECTION_POLL_INTERVAL=60

# JWT / Authentication
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_DAYS=7
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========== Firebase Configuration ==========
# Firebase credentials file path (download from Firebase Console > Project Settings > Service Accounts)
FIREBASE_CREDENTIALS_PATH=config/firebase-credentials.json

# Firebase Project ID
FIREBASE_PROJECT_ID=daa-4th-sem

# Firebase Realtime Database URL
FIREBASE_DATABASE_URL=https://daa-4th-sem.firebaseio.com

# Firebase Storage bucket (e.g., your-project.appspot.com)
FIREBASE_STORAGE_BUCKET=daa-4th-sem.appspot.com

# Use Firestore instead of Realtime Database
USE_FIRESTORE=True

# Firebase Collections
FIREBASE_COLLECTION_STUDENTS=students
FIREBASE_COLLECTION_ATTENDANCE=attendance
FIREBASE_COLLECTION_COURSES=courses
FIREBASE_COLLECTION_EMBEDDINGS=embeddings
FIREBASE_COLLECTION_FACES=student_faces
FIREBASE_COLLECTION_CLASSES=classes
FIREBASE_COLLECTION_PERIODS=periods
FIREBASE_COLLECTION_USERS=users
FIREBASE_COLLECTION_AUTH_TOKENS=auth_tokens
FIREBASE_COLLECTION_SYSTEM_STATE=system_state

# ========== ML Model Configuration ==========
# Model paths and settings
MODEL_WEIGHTS_DIR=models/weights
FACE_DETECTION_MODEL=yolov8n-face.pt
FACE_EMBEDDING_MODEL=facenet_pytorch

# Detection thresholds
FACE_DETECTION_CONFIDENCE=0.5
FACE_RECOGNITION_THRESHOLD=0.6

# ========== CORS Configuration ==========
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://127.0.0.1:3000"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","OPTIONS","PATCH"]
CORS_ALLOW_HEADERS=["*"]

# ========== Frontend (React Dashboard) ==========
# API endpoints
VITE_API_BASE_URL=http://localhost:8000
VITE_API_TIMEOUT=30000

# App configuration
VITE_APP_NAME=Smart Attendance System
VITE_APP_VERSION=1.0.0

# ========== Flutter Mobile App ==========
# Backend API configuration
FLUTTER_API_BASE_URL=http://10.0.2.2:8000
FLUTTER_API_TIMEOUT=30

# For physical devices
# FLUTTER_API_BASE_URL=http://192.168.1.100:8000

# Storage configuration
FLUTTER_SECURE_STORAGE_ENABLE=true

# ========== Optional: Email Configuration ==========
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password

# ========== Optional: AWS/Cloud Configuration ==========
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=attendance-system-bucket

# ========== Optional: File Upload ==========
# MAX_UPLOAD_SIZE_MB=50
# ALLOWED_UPLOAD_TYPES=jpg,png,jpeg,mp4
# UPLOAD_DIR=uploads/

# ========== Optional: Rate Limiting ==========
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW_SECONDS=60

# ========== Optional: Logging ==========
# LOG_FILE_PATH=logs/app.log
# LOG_FILE_MAX_BYTES=10485760
# LOG_FILE_BACKUP_COUNT=10
