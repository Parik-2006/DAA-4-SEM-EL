# FastAPI Configuration
DEBUG=False
ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_DAYS=7

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=True

# Database / Firebase
DATABASE_URL=sqlite:///./attendance.db
REDIS_URL=
FIREBASE_CREDENTIALS_PATH=config/firebase-credentials.json
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=your-cert-url
# Required: set from Firebase Console -> Realtime Database -> Data tab.
# Format A (legacy):  https://<project-id>.firebaseio.com
# Format B (regional): https://<project-id>-default-rtdb.<region>.firebasedatabase.app
# Server startup fails if this is missing/blank/placeholder.
FIREBASE_DATABASE_URL=
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
USE_FIRESTORE=True

# Collections
FIREBASE_COLLECTION_STUDENTS=students
FIREBASE_COLLECTION_ATTENDANCE=attendance
FIREBASE_COLLECTION_COURSES=courses
FIREBASE_COLLECTION_EMBEDDINGS=embeddings
FIREBASE_COLLECTION_FACES=student_faces
FIREBASE_COLLECTION_CLASSES=classes
FIREBASE_COLLECTION_PERIODS=periods
FIREBASE_COLLECTION_USERS=users
FIREBASE_COLLECTION_AUTH_TOKENS=auth_tokens
FIREBASE_COLLECTION_SYSTEM_STATE=system_state

# Attendance timing / period detection
ATTENDANCE_WINDOW_MINUTES=10
LATE_THRESHOLD_MINUTES=5
NOTIFICATION_TRIGGER_MINUTES=5
PERIOD_DETECTION_POLL_INTERVAL=60
ENABLE_PERIOD_DETECTION=True

# ML Model Configuration
YOLOV8_MODEL_PATH=models/weights/yolov8n-face.pt
FACENET_MODEL_PATH=models/weights/facenet_model.pt
FACE_DETECTION_CONFIDENCE=0.5
FACE_RECOGNITION_THRESHOLD=0.6

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=True

# Optional realtime / SSE configuration
WS_HEARTBEAT_INTERVAL=20
SSE_KEEPALIVE_SECONDS=20

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password

# Performance & Optimization
USE_GPU=False
NUM_WORKERS=4
BATCH_SIZE=32
MAX_FILE_SIZE=10485760
CACHE_EMBEDDINGS=True

# Vector Search
USE_FAISS=True
FAISS_INDEX_PATH=indexes/face_embeddings.index
FAISS_METADATA_PATH=indexes/face_metadata.pkl
