# FastAPI Configuration
FASTAPI_ENV=development
FASTAPI_DEBUG=True
FASTAPI_RELOAD=True

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/attendance_system.log

# Model Configuration
# YOLOv8 Model Path
YOLOV8_MODEL_PATH=weights/yolov8n-face.pt
YOLOV8_CONFIDENCE_THRESHOLD=0.5

# FaceNet Configuration
FACENET_MODEL_PATH=weights/facenet_model.pt
FACE_EMBEDDING_DIM=128
FACE_RECOGNITION_THRESHOLD=0.6

# Detection Configuration
DETECTION_IMG_SIZE=640
DETECTION_STRIDE=32
DETECTION_MAX_DET=300

# Face Recognition
FACE_MIN_CONFIDENCE=0.6
FACE_MIN_SIZE=20  # Minimum face pixel size

# Database Configuration - Firebase
# Set FIREBASE_CREDENTIALS_PATH to your Firebase admin SDK JSON file
FIREBASE_CREDENTIALS_PATH=config/firebase-credentials.json
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
USE_FIRESTORE=True  # True for Firestore, False for Realtime Database

# Firebase Collections
FIREBASE_COLLECTION_STUDENTS=students
FIREBASE_COLLECTION_ATTENDANCE=attendance
FIREBASE_COLLECTION_EMBEDDINGS=embeddings
FIREBASE_COLLECTION_SESSIONS=sessions

# Vector Search (FAISS)
USE_FAISS=True
FAISS_INDEX_PATH=indexes/face_embeddings.index
FAISS_METADATA_PATH=indexes/face_metadata.pkl

# Tracking Configuration
TRACK_BUFFER_SIZE=30  # Frames to maintain track
TRACKER_CONFIDENCE_THRESHOLD=0.5

# Stream Configuration
RTSP_BUFFER_SIZE=1  # Reduce buffer for real-time
STREAM_RECONNECT_ATTEMPTS=5
STREAM_RECONNECT_DELAY=5  # seconds

# API Configuration
API_PREFIX=/api/v1
CORS_ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8000", "*"]

# Attendance Settings
MIN_CONSECUTIVE_FRAMES=5  # For temporal verification
FRAME_SKIP=2  # Process every Nth frame
ATTENDANCE_CONFIDENCE_THRESHOLD=0.6

# Performance Settings
PROCESSING_DEVICE=cuda  # cuda or cpu
BATCH_SIZE=32
NUM_WORKERS=4
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:8080"]

# Performance
MAX_WORKERS=4
BATCH_SIZE=8

# Face Embedding Cache
CACHE_EMBEDDINGS=True
CACHE_TTL=3600  # 1 hour in seconds
